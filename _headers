/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; form-action 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; worker-src 'self'
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Cross-Origin-Resource-Policy: same-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), accelerometer=(), gyroscope=(), magnetometer=()
  X-DNS-Prefetch-Control: off

/data/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/*.json
  Cache-Control: public, max-age=86400

# Shell JS/CSS use STABLE filenames (no content hash in the name), so a long
# edge cache keeps serving an old deploy's bytes for up to max-age while a
# fresh index.html (max-age=0) references them: new HTML paired with stale
# JS/CSS, which breaks the site for everyone until the TTL expires or the
# cache is purged. These responses carry ETags, so revalidate-always is
# correct-on-deploy with cheap 304s; the service worker provides the
# long-lived client-side cache for repeat visits and offline.
/*.js
  Cache-Control: public, max-age=0, must-revalidate

/styles.css
  Cache-Control: public, max-age=0, must-revalidate

# Exact-path overrides must come AFTER the /*.js glob: Cloudflare applies every
# matching rule and the LAST one wins, so these would otherwise be clobbered by
# /*.js above. sw.js must never be long-cached or the update mechanism breaks:
# the browser must re-fetch it on every navigation to detect a new BUILD_HASH.
/manual-j-worker.js
  Cache-Control: public, max-age=3600

/sw.js
  Service-Worker-Allowed: /
  Cache-Control: public, max-age=0, must-revalidate
